# DeepSeek API Key (required if using DeepSeek provider)
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Bailian (DashScope) API Key (required if using Bailian provider)
BAILIAN_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# BAILIAN_API_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# Encryption key for database passwords (64 hex characters, auto-generated if not set)
ENCRYPTION_KEY=

# Default MySQL Connection (optional, can also add via UI)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_DATABASE=
